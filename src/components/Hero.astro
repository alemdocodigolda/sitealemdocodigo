---
interface Props {
  hero: any;
}

const { hero } = Astro.props;
---

<section class="hero" id="hero">
  <canvas id="particleCanvas"></canvas>

  <div class="hero-top">
    <h1 class="hero-tagline">
      {hero.titleBefore} <span class="gradient-text">{hero.titleHighlight}</span><br />{hero.titleAfter}
    </h1>
  </div>

  <div class="hero-chat-wrap">
    <div class="hero-chat" id="heroChat">
      <div class="hero-chat-header">
        <div class="hero-chat-avatar">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" stroke="url(#hcg)" stroke-width="2"/>
            <circle cx="9" cy="10" r="1.5" fill="#00d4ff"/>
            <circle cx="15" cy="10" r="1.5" fill="#7c3aed"/>
            <path d="M9 15s1 1.5 3 1.5 3-1.5 3-1.5" stroke="#10b981" stroke-width="1.5" stroke-linecap="round"/>
            <defs>
              <linearGradient id="hcg" x1="0" y1="0" x2="24" y2="24">
                <stop offset="0%" stop-color="#00d4ff"/>
                <stop offset="100%" stop-color="#7c3aed"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div>
          <div class="hero-chat-name">{hero.chatName}</div>
          <div class="hero-chat-status"><span class="status-dot"></span>{hero.statusOnline}</div>
        </div>
        <div class="hero-chat-pills">
          {hero.pills.map((pill: string) => (
            <span class="pill">{pill}</span>
          ))}
        </div>
      </div>

      <div id="heroChatMessages" class="hero-chat-messages"></div>

      <div id="heroChatOptions" class="hero-chat-options"></div>

      <div class="hero-chat-input" id="heroChatInput">
        <div class="hci-field" id="hciField">
          <svg class="hci-icon" width="16" height="16" fill="none" viewBox="0 0 24 24">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <input
            type="text"
            id="hciInput"
            class="hci-real-input"
            placeholder={hero.inputPlaceholder}
            autocomplete="off"
            spellcheck="false"
          />
        </div>
        <button class="hci-send" id="hciSend" aria-label={hero.sendAria}>
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="hero-scroll-hint">
    <span>{hero.scrollHint}</span>
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
      <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<script define:vars={{ heroFlow: hero.flow, unknownMessage: hero.unknownMessage }}>
const flow = heroFlow;

const messagesEl = document.getElementById("heroChatMessages");
const optionsEl = document.getElementById("heroChatOptions");
const inputField = document.getElementById("hciField");
const sendBtn = document.getElementById("hciSend");

function renderMarkdown(text) {
  return text
    .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
    .replace(/\n/g, "<br>");
}

function typewriter(el, html, speed = 18) {
  return new Promise((resolve) => {
    const plain = html.replace(/<[^>]+>/g, "");
    const total = plain.length;
    let i = 0;
    const source = el.dataset.source || "";
    const timer = setInterval(() => {
      i += 2;
      if (i >= total) {
        el.innerHTML = renderMarkdown(source);
        clearInterval(timer);
        resolve();
      } else {
        const visible = source.slice(0, i + source.length - plain.length);
        el.innerHTML = renderMarkdown(visible);
      }
    }, speed);
  });
}

function createBubble() {
  const wrap = document.createElement("div");
  wrap.className = "hc-msg hc-msg-bot";
  wrap.innerHTML = `
    <div class="hc-avatar">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="10" stroke="url(#bm)" stroke-width="2"/>
        <defs><linearGradient id="bm" x1="0" y1="0" x2="24" y2="24">
          <stop offset="0%" stop-color="#00d4ff"/>
          <stop offset="100%" stop-color="#7c3aed"/>
        </linearGradient></defs>
      </svg>
    </div>
    <div class="hc-bubble"></div>`;
  messagesEl.appendChild(wrap);
  messagesEl.scrollTop = messagesEl.scrollHeight;
  return wrap.querySelector(".hc-bubble");
}

function showTyping() {
  const wrap = document.createElement("div");
  wrap.className = "hc-msg hc-msg-bot";
  wrap.id = "hcTyping";
  wrap.innerHTML = `
    <div class="hc-avatar">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="10" stroke="#00d4ff" stroke-width="2"/>
      </svg>
    </div>
    <div class="hc-bubble hc-typing"><span></span><span></span><span></span></div>`;
  messagesEl.appendChild(wrap);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function removeTyping() {
  document.getElementById("hcTyping")?.remove();
}

function addUserMsg(text) {
  const wrap = document.createElement("div");
  wrap.className = "hc-msg hc-msg-user";
  wrap.innerHTML = `<div class="hc-bubble">${text}</div>`;
  messagesEl.appendChild(wrap);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function addLink(linkObj) {
  if (!linkObj) return;
  const el = document.createElement("div");
  el.className = "hc-msg hc-msg-bot hc-link-row";
  el.innerHTML = linkObj.url
    ? `<a href="${linkObj.url}" target="_blank" rel="noopener" class="hc-link-btn">${linkObj.label}</a>`
    : `<span class="hc-link-btn disabled">${linkObj.label}</span>`;
  messagesEl.appendChild(el);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function renderOptions(options) {
  optionsEl.innerHTML = "";
  options.forEach((opt, i) => {
    const btn = document.createElement("button");
    btn.className = "hc-opt";
    btn.style.animationDelay = `${i * 80}ms`;
    btn.textContent = opt.label;
    btn.addEventListener("click", () => handleOption(opt));
    optionsEl.appendChild(btn);
  });
  inputField.classList.add("ready");
}

function handleOption(opt) {
  if (busy) return;
  busy = true;
  addUserMsg(opt.label);
  optionsEl.innerHTML = "";
  inputField.classList.remove("ready");
  setTimeout(async () => {
    await goTo(opt.next);
    busy = false;
  }, 350);
}

async function goTo(stateKey) {
  const state = flow[stateKey];

  for (let i = 0; i < state.bubbles.length; i++) {
    showTyping();
    const delay = 600 + state.bubbles[i].replace(/\*\*/g, "").length * 6;
    await new Promise((r) => setTimeout(r, Math.min(delay, 1600)));
    removeTyping();

    const bubble = createBubble();
    bubble.dataset.source = state.bubbles[i];
    await typewriter(bubble, renderMarkdown(state.bubbles[i]));

    if (i < state.bubbles.length - 1) {
      await new Promise((r) => setTimeout(r, 280));
    }
  }

  if (state.link) {
    await new Promise((r) => setTimeout(r, 150));
    addLink(state.link);
  }

  if (state.scrollTo) {
    await new Promise((r) => setTimeout(r, 600));
    document.getElementById(state.scrollTo)?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  await new Promise((r) => setTimeout(r, 250));
  renderOptions(state.options);
}

const inputEl = document.getElementById("hciInput");

const routes = [
  { keys: ["crmcredito", "crm"], next: "crmcredito" },
  { keys: ["creditocasa", "casa", "home", "house", "imovel", "imóvel", "vivienda", "logement"], next: "creditocasa" },
  { keys: ["simulasite", "simulador", "simulator", "simulador", "calculadora", "calculator", "simulateur"], next: "simulasite" },
  { keys: ["pededir", "documento", "documentos", "document", "documents", "documentos"], next: "pededirdoc" },
  { keys: ["projeto", "projetos", "project", "projects", "proyecto", "proyectos", "projet", "projets", "produto", "produtos", "product", "products"], next: "projetos" },
  { keys: ["tecnologia", "technology", "tecnología", "technologie", "ia", "ai", "inteligencia", "inteligência", "intelligence", "llm"], next: "tecnologia" },
  { keys: ["quem", "somos", "who", "about", "quien", "quién", "sommes", "apropos", "à propos", "sobre"], next: "quemSomos" },
  { keys: ["contacto", "contact", "contacto", "contato", "mail", "email", "e-mail", "telefone", "teléfono", "telefono", "phone", "where", "donde", "ou", "onde", "morada", "adresse", "faro"], next: "contacto" },
];

function normalize(str) {
  return str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
}

function matchRoute(text) {
  const n = normalize(text);
  for (const route of routes) {
    if (route.keys.some((k) => n.includes(normalize(k)))) return route.next;
  }
  return null;
}

let busy = false;

async function submitText() {
  if (busy) return;
  const text = inputEl.value.trim();
  if (!text) return;
  inputEl.value = "";
  optionsEl.innerHTML = "";
  inputField.classList.remove("ready");
  addUserMsg(text);

  const next = matchRoute(text);
  busy = true;
  if (next) {
    await new Promise((r) => setTimeout(r, 350));
    await goTo(next);
  } else {
    showTyping();
    await new Promise((r) => setTimeout(r, 1000));
    removeTyping();
    const bubble = createBubble();
    bubble.dataset.source = unknownMessage;
    await typewriter(bubble, renderMarkdown(bubble.dataset.source));
    await new Promise((r) => setTimeout(r, 300));
    renderOptions(flow.start.options);
  }
  busy = false;
}

inputEl.addEventListener("keydown", (e) => {
  if (e.key === "Enter") submitText();
});
sendBtn.addEventListener("click", submitText);
inputEl.addEventListener("focus", () => inputField.classList.add("ready"));
inputEl.addEventListener("blur", () => inputField.classList.remove("ready"));

setTimeout(() => goTo("start"), 500);
</script>
