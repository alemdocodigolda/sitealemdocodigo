---
interface Props {
  footer: any;
}

const { footer } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-glow"></div>
  <div class="container">

    <div class="footer-inner">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="#" class="logo">
          <span class="logo-symbol">&lt;</span>além do código<span class="logo-symbol">/&gt;</span>
        </a>
        <p class="footer-tagline">{footer.brand}</p>
        <p class="footer-location">
          <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-right:4px">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="10" r="3" stroke-linecap="round"/>
          </svg>
          Faro, Portugal
        </p>
      </div>

      <!-- Links -->
      <div class="footer-links">

        <div class="footer-col">
          <strong>{footer.projectsTitle}</strong>
          <a href="https://www.crmcredito.pt" target="_blank" rel="noopener">CRM Crédito</a>
          <a href="https://www.creditocasa.pt" target="_blank" rel="noopener">CréditoCasa.pt</a>
          <a href="https://www.simulasite.pt" target="_blank" rel="noopener">SimulaSite</a>
          <span class="footer-link-muted">Pedir Documentos</span>
        </div>

        <div class="footer-col">
          <strong>{footer.companyTitle}</strong>
          <a href="#sobre">{footer.aboutLink}</a>
          <a href="#projetos">{footer.projectsLink}</a>
          <a href="#contacto">{footer.contactLink}</a>
        </div>

        <div class="footer-col">
          <strong>Legal</strong>
          <a href="/termos">Termos e Condições</a>
          <a href="/privacidade">Política de Privacidade</a>
        </div>

      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>© {year} Além do Código. Todos os direitos reservados.</p>
    </div>

  </div>
</footer>
