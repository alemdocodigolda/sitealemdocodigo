---
interface Props {
  contact: any;
}

const { contact } = Astro.props;
const cmds = contact.panel.terminalCommands;
const submitTexts = {
  default: contact.form.submitDefault,
  sending: contact.form.submitSending,
  success: contact.form.submitSuccess,
};
const validationTexts = {
  required: contact.form.errorRequired,
  email: contact.form.errorEmail,
};
---

<section class="section section-contact" id="contacto">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-panel">
        <div class="panel-header">
          <div class="panel-dots">
            <button class="pd red" id="dotRed" aria-label={contact.panel.redTooltip}>
              <span class="pd-tooltip">{contact.panel.redTooltip}</span>
            </button>
            <button class="pd yellow" id="dotYellow" aria-label={contact.panel.yellowTooltip}>
              <span class="pd-tooltip">{contact.panel.yellowTooltip}</span>
            </button>
            <button class="pd green" id="dotGreen" aria-label={contact.panel.greenTooltip}>
              <span class="pd-tooltip">{contact.panel.greenTooltip}</span>
            </button>
          </div>
          <span class="panel-title">{contact.panel.title}</span>
          <span class="panel-ping">
            <span class="ping-dot"></span>
            {contact.panel.online}
          </span>
        </div>

        <div class="panel-body">
          <div class="section-tag">{contact.panel.tag}</div>
          <h2 class="section-title">{contact.panel.headingBefore} <span class="gradient-text">{contact.panel.headingHighlight}</span></h2>
          <p class="panel-desc">{contact.panel.description}</p>

          <div class="conn-nodes">
            <div class="conn-node">
              <div class="node-icon">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/>
                </svg>
              </div>
              <div class="node-info">
                <span class="node-label">{contact.panel.locationLabel}</span>
                <span class="node-value">R. Dom Francisco Gomes 4 1A, Faro</span>
              </div>
              <div class="node-status"></div>
            </div>

            <div class="conn-line"></div>

            <div class="conn-node">
              <div class="node-icon">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.82 19.79 19.79 0 01.12 2.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.09a16 16 0 006 6l.46-.46a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="node-info">
                <span class="node-label">{contact.panel.phoneLabel}</span>
                <a href="tel:+351967015157" class="node-value node-link">+351 967 015 157</a>
              </div>
              <div class="node-status"></div>
            </div>

          </div>

          <div class="terminal-hint">
            <span class="th-prompt">$</span>
            <span class="th-cmd" id="terminalCmd"></span>
            <span class="code-cursor"></span>
          </div>
        </div>
      </div>

      <div class="contact-form-panel">
        <form
          class="contact-form"
          id="contactForm"
          action="https://formspree.io/f/mvzbnyjo"
          method="POST"
          novalidate
        >
          <div class="cf-row">
            <div class="cf-group">
              <label for="cf-nome">{contact.form.nameLabel}</label>
              <input type="text" id="cf-nome" name="nome" placeholder={contact.form.namePlaceholder} required />
              <span class="cf-error" id="err-nome"></span>
            </div>
            <div class="cf-group">
              <label for="cf-empresa">{contact.form.companyLabel}</label>
              <input type="text" id="cf-empresa" name="empresa" placeholder={contact.form.companyPlaceholder} />
            </div>
          </div>

          <div class="cf-row">
            <div class="cf-group">
              <label for="cf-email">{contact.form.emailLabel}</label>
              <input type="email" id="cf-email" name="email" placeholder={contact.form.emailPlaceholder} required />
              <span class="cf-error" id="err-email"></span>
            </div>
            <div class="cf-group">
              <label for="cf-contacto">{contact.form.contactLabel}</label>
              <input type="tel" id="cf-contacto" name="contacto" placeholder={contact.form.contactPlaceholder} />
            </div>
          </div>

          <div class="cf-group">
            <label for="cf-servico">{contact.form.reasonLabel}</label>
            <div class="cf-select-wrap">
              <select id="cf-servico" name="servico" required>
                <option value="">{contact.form.reasonPlaceholder}</option>
                {contact.form.reasonOptions.map((opt: string) => (
                  <option>{opt}</option>
                ))}
              </select>
              <svg class="cf-select-arrow" width="14" height="14" fill="none" viewBox="0 0 24 24">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="cf-error" id="err-servico"></span>
          </div>

          <div class="cf-group cf-group-grow">
            <label for="cf-msg">{contact.form.messageLabel}</label>
            <textarea id="cf-msg" name="mensagem" placeholder={contact.form.messagePlaceholder} required></textarea>
            <span class="cf-error" id="err-msg"></span>
          </div>

          <button type="submit" class="cf-submit" id="cfSubmit">
            <span class="cf-submit-text">{contact.form.submitDefault}</span>
            <svg class="cf-submit-icon" width="16" height="16" fill="none" viewBox="0 0 24 24">
              <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>


        </form>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ terminalCommands: cmds, submitTexts, validationTexts }}>
  document.getElementById("dotRed")?.addEventListener("click", () => {
    window.open("https://wa.me/351967015157", "_blank");
  });

  document.getElementById("dotYellow")?.addEventListener("click", () => {
    window.location.href = "tel:+351967015157";
  });

  document.getElementById("dotGreen")?.addEventListener("click", () => {
    const msg = document.getElementById("cf-msg");
    if (msg) {
      msg.scrollIntoView({ behavior: "smooth", block: "center" });
      setTimeout(() => msg.focus(), 400);
    }
  });

  let ci = 0;
  let ci2 = 0;
  let deleting = false;
  const terminalEl = document.getElementById("terminalCmd");

  if (terminalEl) {
    function typeCmd() {
      const cmd = terminalCommands[ci];
      if (!deleting) {
        terminalEl.textContent = cmd.slice(0, ci2 + 1);
        ci2++;
        if (ci2 === cmd.length) {
          deleting = true;
          setTimeout(typeCmd, 1800);
          return;
        }
      } else {
        terminalEl.textContent = cmd.slice(0, ci2 - 1);
        ci2--;
        if (ci2 === 0) {
          deleting = false;
          ci = (ci + 1) % terminalCommands.length;
        }
      }
      setTimeout(typeCmd, deleting ? 32 : 58);
    }

    setTimeout(typeCmd, 600);
  }

  function setError(id, msg) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
    const group = el.closest('.cf-group');
    if (group) group.classList.toggle('has-error', !!msg);
  }

  function validateForm() {
    let valid = true;
    const nome = document.getElementById('cf-nome');
    const email = document.getElementById('cf-email');
    const servico = document.getElementById('cf-servico');
    const msg = document.getElementById('cf-msg');

    if (!nome.value.trim()) { setError('err-nome', validationTexts.required); valid = false; }
    else setError('err-nome', '');

    const emailVal = email.value.trim();
    if (!emailVal) { setError('err-email', validationTexts.required); valid = false; }
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) { setError('err-email', validationTexts.email); valid = false; }
    else setError('err-email', '');

    if (!servico.value) { setError('err-servico', validationTexts.required); valid = false; }
    else setError('err-servico', '');

    if (!msg.value.trim()) { setError('err-msg', validationTexts.required); valid = false; }
    else setError('err-msg', '');

    return valid;
  }

  const form = document.getElementById("contactForm");
  const btn = document.getElementById("cfSubmit");

  if (form && btn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!validateForm()) return;
      const span = btn.querySelector(".cf-submit-text");
      btn.disabled = true;
      span.textContent = submitTexts.sending;
      btn.classList.add("sending");

      try {
        const res = await fetch(form.action, {
          method: "POST",
          headers: {
            Accept: "application/json",
          },
          body: new FormData(form),
        });

        if (!res.ok) throw new Error();

        span.textContent = submitTexts.success;
        btn.classList.remove("sending");
        btn.classList.add("sent");
        setTimeout(() => {
          span.textContent = submitTexts.default;
          btn.disabled = false;
          btn.classList.remove("sent");
          form.reset();
        }, 3000);
      } catch {
        span.textContent = submitTexts.default;
        btn.disabled = false;
        btn.classList.remove("sending");
      }
    });
  }
</script>
