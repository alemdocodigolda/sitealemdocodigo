---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Sobre from "../components/Sobre.astro";
import Projetos from "../components/Projetos.astro";
import Contacto from "../components/Contacto.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { siteContent, type Lang } from "../i18n/site";

const lang: Lang = "pt";
const content = siteContent[lang];
---

<Layout lang={lang}>
  <Nav lang={lang} nav={content.nav} />
  <Hero hero={content.hero} />
  <Sobre about={content.about} />
  <Projetos projects={content.projects} />
  <Contacto contact={content.contact} />
  <Footer footer={content.footer} />

  <!-- Sticky CTA mobile -->
  <button type="button" class="sticky-cta" id="stickyCta" aria-label="Contacte-nos">
    <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Contacte-nos
  </button>

  <script src="../scripts/main.js"></script>
</Layout>
